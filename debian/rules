#!/usr/bin/make -f

PYBUILD_TEST_PYTEST = 1
export PYBUILD_TEST_PYTEST

%:
	dh $@ --with python3 --buildsystem=pybuild


override_dh_auto_install:
	bash -c 'rm -rf .pybuild/*/*/*.{key,pem,srl,sock}'
	dh_auto_install

override_dh_install:
	dh_install
	install -m644 javascript/index.js debian/libjs-entanglement/usr/share/javascript/entanglement/entanglement.js/entanglement.js
